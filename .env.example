PORT=5000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# Database
# DATABASE_URL=postgresql://user:pass@localhost:5432/ecotrack
# DB_SSL_REJECT_UNAUTHORIZED=true    # Set to false only for self-signed cert dev environments

# Authentication
# JWT_SECRET=your-secret-here-minimum-32-chars-CHANGE-IN-PRODUCTION!!
#   ^ REQUIRED in production. Server exits on startup if missing.
#   ^ Must be at minimum 32 random characters. Use: openssl rand -hex 32

# AUTH_REQUIRED=true
#   ^ Set to true in production to enforce JWT on ALL API routes.
#   ^ When true, unauthenticated requests are rejected with HTTP 401.
#   ^ Default (unset/false): stub user fallback active — suitable for local dev only.

# SEED_USER_PASSWORD_HASH=$argon2id$...
#   ^ Argon2id hash for the default seeded user. If not set in production,
#   ^ the default account is locked with a random placeholder (cannot be used to login).
#   ^ Generate with: node -e "require('argon2').hash('yourpassword').then(console.log)"
